let charts={};
let reportFilters={dept:'',hotel:'',estado:'',prio:'',fechaDesde:'',fechaHasta:''};

function showView(view){
  document.getElementById('view-solicitudes').style.display=view==='solicitudes'?'block':'none';
  document.getElementById('view-reportes').style.display=view==='reportes'?'block':'none';
  document.getElementById('nav-solicitudes').classList.toggle('active',view==='solicitudes');
  document.getElementById('nav-reportes').classList.toggle('active',view==='reportes');
  if(view==='reportes') renderReports();
}

function getReportTickets(){
  return allTickets.filter(t=>{
    if(reportFilters.dept&&t.departamento!==reportFilters.dept)return false;
    if(reportFilters.hotel&&t.hotel!==reportFilters.hotel)return false;
    if(reportFilters.estado&&t.estado!==reportFilters.estado)return false;
    if(reportFilters.prio&&t.prioridad!==reportFilters.prio)return false;
    if(reportFilters.fechaDesde&&t.fecha<reportFilters.fechaDesde)return false;
    if(reportFilters.fechaHasta&&t.fecha>reportFilters.fechaHasta)return false;
    return true;
  });
}

function applyReportFilter(){
  reportFilters.dept=document.getElementById('rf-dept').value;
  reportFilters.hotel=document.getElementById('rf-hotel').value;
  reportFilters.estado=document.getElementById('rf-estado').value;
  reportFilters.prio=document.getElementById('rf-prio').value;
  reportFilters.fechaDesde=document.getElementById('rf-desde').value;
  reportFilters.fechaHasta=document.getElementById('rf-hasta').value;
  renderReports();
}

function clearReportFilter(){
  ['rf-dept','rf-hotel','rf-estado','rf-prio'].forEach(id=>document.getElementById(id).value='');
  ['rf-desde','rf-hasta'].forEach(id=>document.getElementById(id).value='');
  reportFilters={dept:'',hotel:'',estado:'',prio:'',fechaDesde:'',fechaHasta:''};
  renderReports();
}

function renderReports(){
  const tickets=getReportTickets();
  const now=new Date();
  document.getElementById('report-sub').textContent='Actualizado '+now.toLocaleTimeString('es-HN',{hour:'2-digit',minute:'2-digit'})+' · '+tickets.length+' tickets';
  document.getElementById('r-total').textContent=tickets.length;
  document.getElementById('r-abierto').textContent=tickets.filter(t=>t.estado==='Abierto').length;
  document.getElementById('r-proceso').textContent=tickets.filter(t=>t.estado==='En proceso').length;
  document.getElementById('r-resuelto').textContent=tickets.filter(t=>t.estado==='Resuelto').length;

  const count=(key,vals)=>vals.map(v=>tickets.filter(t=>t[key]===v).length);
  const COLORS=['#185FA5','#854F0B','#3B6D11','#5F5E5A','#6B21A8','#A32D2D','#2E5FA8','#5A7A00','#CC5500','#1A6B2A','#7B4F2E','#92700A','#555555'];
  const LIGHT=['#E6F1FB','#FAEEDA','#EAF3DE','#F1EFE8','#F0EAFB','#FCEBEB','#E8EEF9','#F4F9E4','#FFF0E6','#E8F5E9','#F3E5D8','#FFF9C4','#F0F0F0'];

  function makeChart(id,type,labels,data,colors,bgColors){
    if(charts[id]){charts[id].destroy();delete charts[id];}
    const canvas=document.getElementById(id);
    if(!canvas)return;
    const ctx=canvas.getContext('2d');
    charts[id]=new Chart(ctx,{
      type,
      data:{labels,datasets:[{data,backgroundColor:bgColors||colors,borderColor:type==='doughnut'?bgColors||colors:colors,borderWidth:type==='bar'?0:2,borderRadius:type==='bar'?4:0}]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:type==='bar'?'bottom':'right',labels:{font:{size:10},boxWidth:10,padding:8}}},
        scales:type==='bar'?{y:{beginAtZero:true,ticks:{stepSize:1,font:{size:10}},grid:{color:'rgba(0,0,0,0.04)'}},x:{ticks:{font:{size:10}},grid:{display:false}}}:{}}
    });
  }

  makeChart('chart-estado','doughnut',['Abierto','En proceso','Resuelto','Cerrado'],count('estado',['Abierto','En proceso','Resuelto','Cerrado']),['#185FA5','#854F0B','#3B6D11','#5F5E5A'],['#E6F1FB','#FAEEDA','#EAF3DE','#F1EFE8']);
  makeChart('chart-dept','doughnut',['TI','Mantenimiento'],count('departamento',['TI','Mantenimiento']),['#185FA5','#6B21A8'],['#E6F1FB','#F0EAFB']);
  const hoteles=['Hotel Plaza Juan Carlos','Hotel Plaza San Martín','Hotel Plaza del Libertador','Hotel Plaza del General'];
  makeChart('chart-hotel','bar',hoteles.map(h=>h.replace('Hotel Plaza ','')),count('hotel',hoteles),COLORS,LIGHT);
  makeChart('chart-prio','doughnut',['Alta','Media','Baja'],count('prioridad',['Alta','Media','Baja']),['#A32D2D','#854F0B','#3B6D11'],['#FCEBEB','#FAEEDA','#EAF3DE']);
  const allCats=[...CATS.TI,...CATS.Mantenimiento];
  const nonZero=allCats.map((c,i)=>({c,n:tickets.filter(t=>t.categoria===c).length})).filter(x=>x.n>0).sort((a,b)=>b.n-a.n);
  makeChart('chart-cat','bar',nonZero.map(x=>x.c),nonZero.map(x=>x.n),COLORS,LIGHT);
}

function exportExcel(){
  try{
    const tickets=getReportTickets();
    if(!tickets.length){showToast('No hay tickets para exportar',true);return;}
    const headers=['Código','Título','Descripción','Departamento','Hotel','Categoría','Estado','Prioridad','Solicitante','Correo','Fecha','Observación'];
    const rows=tickets.map(t=>[t.codigo,t.titulo,t.descripcion,t.departamento,t.hotel,t.categoria,t.estado,t.prioridad,t.solicitante,t.user_email,t.fecha,t.observacion]);
    const esc=v=>'"'+(String(v||'').replace(/"/g,'""'))+'"';
    const csv='﻿'+[headers,...rows].map(r=>r.map(esc).join(',')).join('
');
    const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url;
    a.download='Reporte_Tickets_'+new Date().toISOString().slice(0,10)+'.csv';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('Reporte exportado — '+tickets.length+' tickets');
  }catch(e){showToast('Error al exportar: '+e.message,true);}
}

function showToast(msg,isError=false){
  const el=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  document.getElementById('toast-icon').className=isError?'ti ti-alert-circle':'ti ti-check';
  el.className='toast show'+(isError?' error':'');
  setTimeout(()=>el.classList.remove('show'),4000);
}

