const catBg={Red:'#E6F1FB',Hardware:'#E6F1FB',Software:'#E6F1FB',Accesos:'#E6F1FB',Impresoras:'#E6F1FB','UPS':'#E6F1FB','Cámaras':'#E6F1FB','Soporte SKILL':'#E6F1FB','Pintura':'#FFF9C4','Tabla yeso':'#FFF9C4','Albañilería':'#FFF9C4','Diseño':'#FFF9C4','Tapiz/Alfombra':'#FFF9C4','Carpintería':'#F3E5D8','Aire acondicionado y Refrigeración':'#E8F5E9','Electricidad y Torre':'#FFF0E6','Compras':'#F4F9E4','Tapicería':'#F0EAF9','Taller de Soldadura':'#F0F0F0','Fontanería':'#FFEBEE','Ascensores':'#E8EEF9'};

const statClass={Abierto:'b-abierto','En proceso':'b-en-proceso',Resuelto:'b-resuelto',Cerrado:'b-cerrado'};
const prioClass={Alta:'prio-alta',Media:'prio-media',Baja:'prio-baja'};
const prioIcon={Alta:'ti-arrow-up',Media:'ti-minus',Baja:'ti-arrow-down'};

let allTickets=[],currentId=null,nextNum=1,currentUser=null,userRole=null,userDept=null,deptFilter='todos';

function pad(n){return 'TK-'+String(n).padStart(3,'0')}
function today(){return new Date().toISOString().slice(0,10)}
function fmt(d){if(!d)return '—';const[y,m,dy]=d.split('-');return dy+'/'+m+'/'+y}
function initials(n){return(n||'?').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase()}
function isAdmin(){return userRole==='superadmin'||userRole==='admin'}

function togglePass(inputId,eyeId){
  const input=document.getElementById(inputId);
  const eye=document.getElementById(eyeId);
  if(input.type==='password'){input.type='text';eye.className='ti ti-eye-off';}
  else{input.type='password';eye.className='ti ti-eye';}
}

function switchTab(t){
  document.getElementById('tab-login').classList.toggle('active',t==='login');
  document.getElementById('tab-register').classList.toggle('active',t==='register');
  document.getElementById('form-login').style.display=t==='login'?'block':'none';
  document.getElementById('form-register').style.display=t==='register'?'block':'none';
  document.getElementById('login-msg').style.display='none';
}

function showMsg(msg,isError=true){
  const el=document.getElementById('login-msg');
  el.textContent=msg;el.className='login-msg '+(isError?'error':'success');el.style.display='block';
}

async function doLogin(){
  const email=document.getElementById('l-email').value.trim();
  const pass=document.getElementById('l-pass').value;
  if(!email||!pass){showMsg('Completa todos los campos');return;}
  const btn=document.getElementById('btn-login');btn.disabled=true;btn.textContent='Entrando…';
  const{data,error}=await sb.auth.signInWithPassword({email,password:pass});
  if(error){showMsg(error.message);btn.disabled=false;btn.textContent='Iniciar sesión';return;}
  await initApp(data.user);
}

async function doRegister(){
  const name=document.getElementById('r-name').value.trim();
  const email=document.getElementById('r-email').value.trim();
  const pass=document.getElementById('r-pass').value;
  if(!name||!email||!pass){showMsg('Completa todos los campos');return;}
  if(pass.length<6){showMsg('La contraseña debe tener al menos 6 caracteres');return;}
  const btn=document.getElementById('btn-register');btn.disabled=true;btn.textContent='Creando cuenta…';
  const{error}=await sb.auth.signUp({email,password:pass,options:{data:{full_name:name}}});
  if(error){showMsg(error.message);btn.disabled=false;btn.textContent='Crear cuenta';return;}
  showMsg('Cuenta creada. Ya puedes iniciar sesión.',false);
  btn.disabled=false;btn.textContent='Crear cuenta';switchTab('login');
  document.getElementById('l-email').value=email;
}

async function doLogout(){
  await sb.auth.signOut();
  currentUser=null;userRole=null;userDept=null;
  document.getElementById('app-wrap').classList.remove('visible');
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('l-pass').value='';
}

async function initApp(user){
  currentUser=user;
  const{data:adminData}=await sb.from('admins').select('rol,departamento').eq('email',user.email).single();
  userRole=adminData?.rol||'user';
  userDept=adminData?.departamento||null;
  document.getElementById('login-screen').style.display='none';
  document.getElementById('app-wrap').classList.add('visible');
  const name=user.user_metadata?.full_name||user.email;
  document.getElementById('topbar-name').textContent=name;
  document.getElementById('topbar-avatar').textContent=initials(name);
  const badge=document.getElementById('topbar-role-badge');
  if(userRole==='superadmin'){badge.textContent='Super Admin';badge.className='role-badge role-superadmin';badge.style.display='inline-flex';}
  else if(userRole==='admin'&&userDept==='TI'){badge.textContent='Admin TI';badge.className='role-badge role-admin-ti';badge.style.display='inline-flex';}
  else if(userRole==='admin'&&userDept==='Mantenimiento'){badge.textContent='Admin Mantenimiento';badge.className='role-badge role-admin-mant';badge.style.display='inline-flex';}
  else{badge.style.display='none';}
  document.getElementById('dept-tabs-wrap').style.display=userRole==='superadmin'?'block':'none';
  document.getElementById('nav-tabs-wrap').style.display=isAdmin()?'block':'none';
  document.getElementById('stats-wrap').style.display=isAdmin()?'block':'none';
  if(userRole==='admin'&&userDept)deptFilter=userDept;
  document.getElementById('page-title').textContent=userRole==='superadmin'?'Todas las solicitudes':userRole==='admin'?'Solicitudes — '+userDept:'Mis solicitudes';
  updateFilterCats();
  await loadTickets();
}

function updateFilterCats(){
  const sel=document.getElementById('f-cat');
  const cats=deptFilter==='todos'?[...CATS.TI,...CATS.Mantenimiento]:CATS[deptFilter]||[];
  sel.innerHTML='<option value="">Todas las categorías</option>'+cats.map(c=>'<option>'+c+'</option>').join('');
}

function setDeptFilter(dept){
  deptFilter=dept;
  ['todos','TI','Mantenimiento'].forEach(d=>{document.getElementById('tab-'+d).classList.toggle('active',d===dept);});
  updateFilterCats();render();
}

async function loadTickets(){
  let query=sb.from('tickets').select('*').order('id',{ascending:false});
  if(!isAdmin())query=query.eq('user_id',currentUser.id);
  else if(userRole==='admin'&&userDept)query=query.eq('departamento',userDept);
  const{data,error}=await query;
  if(error){showToast('Error: '+error.message,true);return;}
  allTickets=data||[];
  if(allTickets.length>0){const m=Math.max(...allTickets.map(t=>parseInt(t.codigo.replace('TK-',''))||0));nextNum=m+1;}
  const now=new Date();
  document.getElementById('page-sub').textContent='Actualizado '+now.toLocaleTimeString('es-HN',{hour:'2-digit',minute:'2-digit'});
  render();
}

function getFiltered(){
  if(!isAdmin())return allTickets;
  const q=document.getElementById('search').value.toLowerCase();
  const est=document.getElementById('f-estado').value;
  const cat=document.getElementById('f-cat').value;
  const hotel=document.getElementById('f-hotel').value;
  const prio=document.getElementById('f-prio').value;
  return allTickets.filter(t=>{
    if(deptFilter!=='todos'&&t.departamento!==deptFilter)return false;
    if(q&&!t.titulo.toLowerCase().includes(q)&&!(t.descripcion||'').toLowerCase().includes(q))return false;
    if(est&&t.estado!==est)return false;
    if(cat&&t.categoria!==cat)return false;
    if(hotel&&t.hotel!==hotel)return false;
    if(prio&&t.prioridad!==prio)return false;
    return true;
  });
}

function catBadge(cat){
  return '<span class="badge" style="background:'+(catBg[cat]||'#f0efe9')+';color:'+(catColor[cat]||'#6b6a65')+'"><i class="ti '+(catIcon[cat]||'ti-help-circle')+'" style="margin-right:3px"></i>'+cat+'</span>';
}

function render(){
  if(isAdmin()){
    const src=deptFilter==='todos'?allTickets:allTickets.filter(t=>t.departamento===deptFilter);
    document.getElementById('s-total').textContent=src.length;
    document.getElementById('s-open').textContent=src.filter(t=>t.estado==='Abierto').length;
    document.getElementById('s-proc').textContent=src.filter(t=>t.estado==='En proceso').length;
    document.getElementById('s-done').textContent=src.filter(t=>t.estado==='Resuelto').length;
  }
  const list=getFiltered();
  const el=document.getElementById('list');
  if(!list.length){el.innerHTML='<div class="empty"><i class="ti ti-ticket-off"></i>No hay solicitudes que mostrar.<br><br><button onclick="openNew()" style="margin-top:8px;background:var(--text);color:var(--bg);border:none;border-radius:8px;padding:8px 16px;cursor:pointer;font-size:13px">Crear primera solicitud</button></div>';return;}
  el.innerHTML=list.map(t=>{
    const deptBadge=t.departamento==='TI'?'<span class="badge b-ti">TI</span>':'<span class="badge b-mant">Mantenimiento</span>';
    return '<div class="ticket" onclick="openDet('+t.id+')" role="button" tabindex="0">'
      +'<div class="ticket-top"><div class="ticket-title">'+t.titulo+'</div><div class="ticket-id">'+t.codigo+'</div></div>'
      +'<div class="ticket-meta"><span class="badge '+(statClass[t.estado]||'b-abierto')+'">'+t.estado+'</span>'+deptBadge+catBadge(t.categoria)
      +'<span class="cat-tag"><i class="ti ti-building" style="margin-right:3px"></i>'+(t.hotel||'—')+'</span></div>'
      +'<div class="ticket-desc">'+(t.descripcion||'')+'</div>'
      +'<div class="ticket-foot"><div class="user-info-row"><span class="avatar">'+initials(t.solicitante)+'</span>'+(t.solicitante||'—')+'</div>'
      +'<div style="display:flex;align-items:center;gap:10px"><span class="prio '+prioClass[t.prioridad]+'"><i class="ti '+prioIcon[t.prioridad]+'"></i>'+t.prioridad+'</span><span class="date">'+fmt(t.fecha)+'</span></div></div>'
      +'</div>';
  }).join('');
}

function updateCats(){
  const dept=document.getElementById('n-dept').value;
  document.getElementById('n-cat').innerHTML=CATS[dept].map(c=>'<option>'+c+'</option>').join('');
}

function openNew(){updateCats();document.getElementById('modal-new').classList.add('open');}
function closeNew(){
  document.getElementById('modal-new').classList.remove('open');
  document.getElementById('n-title').value='';
  document.getElementById('n-desc').value='';
  document.getElementById('n-hotel').value='';
  document.getElementById('btn-create').disabled=false;
  document.getElementById('btn-create').textContent='Enviar solicitud';
}

async function createTicket(){
  const hotel=document.getElementById('n-hotel').value;
  const titulo=document.getElementById('n-title').value.trim();
  if(!hotel){document.getElementById('n-hotel').focus();return;}
  if(!titulo){document.getElementById('n-title').focus();return;}
  const btn=document.getElementById('btn-create');btn.disabled=true;btn.textContent='Enviando…';
  const nombre=currentUser.user_metadata?.full_name||currentUser.email;
  const codigo=pad(nextNum);
  const dept=document.getElementById('n-dept').value;
  const{error}=await sb.from('tickets').insert([{
    codigo,titulo,
    descripcion:document.getElementById('n-desc').value.trim()||'Sin descripción adicional.',
    categoria:document.getElementById('n-cat').value,
    prioridad:document.getElementById('n-prio').value,
    estado:'Abierto',solicitante:nombre,fecha:today(),
    user_id:currentUser.id,user_email:currentUser.email,
    departamento:dept,hotel:hotel
  }]);
  if(error){showToast('Error: '+error.message,true);btn.disabled=false;btn.textContent='Enviar solicitud';return;}
  nextNum++;closeNew();await loadTickets();showToast('Solicitud '+codigo+' enviada correctamente');
}

function openDet(id){
  currentId=id;
  const t=allTickets.find(x=>x.id===id);
  document.getElementById('d-id').textContent=t.codigo;
  document.getElementById('d-title').textContent=t.titulo;
  document.getElementById('d-body').textContent=t.descripcion||'Sin descripción.';
  const deptBadge=t.departamento==='TI'?'<span class="badge b-ti">TI</span>':'<span class="badge b-mant">Mantenimiento</span>';
  document.getElementById('d-badges').innerHTML='<span class="badge '+(statClass[t.estado]||'b-abierto')+'">'+t.estado+'</span>'+deptBadge+catBadge(t.categoria)+'<span class="prio '+prioClass[t.prioridad]+'" style="font-size:12px;display:flex;align-items:center;gap:3px"><i class="ti '+prioIcon[t.prioridad]+'"></i>Prioridad '+t.prioridad+'</span>';
  document.getElementById('d-info').innerHTML='<div class="di"><div class="di-label">Solicitante</div><div class="di-val">'+(t.solicitante||'—')+'</div></div><div class="di"><div class="di-label">Correo</div><div class="di-val">'+(t.user_email||'—')+'</div></div><div class="di"><div class="di-label">Hotel</div><div class="di-val">'+(t.hotel||'—')+'</div></div><div class="di"><div class="di-label">Fecha</div><div class="di-val">'+fmt(t.fecha)+'</div></div>';
  // Observacion
  if(isAdmin()){
    document.getElementById('obs-wrap').style.display='block';
    document.getElementById('obs-view').style.display='none';
    document.getElementById('obs-text').value=t.observacion||'';
  } else {
    document.getElementById('obs-wrap').style.display='none';
    if(t.observacion){
      document.getElementById('obs-view').style.display='block';
      document.getElementById('obs-content').textContent=t.observacion;
    } else {
      document.getElementById('obs-view').style.display='none';
    }
  }
  document.getElementById('admin-actions').style.display=isAdmin()?'block':'none';
  document.getElementById('btn-delete').style.display=isAdmin()?'inline-flex':'none';
  if(isAdmin()){
    const estados=['Abierto','En proceso','Resuelto','Cerrado'];
    document.getElementById('d-status').innerHTML=estados.map(e=>{
      const blocked=e==='Cerrado'&&t.estado!=='Resuelto';
      return '<button class="status-btn '+(e===t.estado?'active':'')+'" '+(blocked?'disabled title="El ticket debe estar Resuelto primero"':'onclick="setStatus(\''+e+'\')"')+'>'+e+'</button>';
    }).join('');
  }
  document.getElementById('modal-det').classList.add('open');
}

function closeDet(){document.getElementById('modal-det').classList.remove('open');currentId=null;}

async function setStatus(est){
  const{error}=await sb.from('tickets').update({estado:est}).eq('id',currentId);
