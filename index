<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soporte — Distrito Hotelero Plaza San Martín</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#ffffff;--bg2:#f7f7f5;--bg3:#f0efe9;--text:#1a1a1a;--text2:#6b6a65;--text3:#9a9891;--border:rgba(0,0,0,0.12);--border2:rgba(0,0,0,0.22);--radius:8px;--radius-lg:12px;--blue-bg:#E6F1FB;--blue-text:#185FA5;--amber-bg:#FAEEDA;--amber-text:#854F0B;--green-bg:#EAF3DE;--green-text:#3B6D11;--gray-bg:#F1EFE8;--gray-text:#5F5E5A;--red-bg:#FCEBEB;--red-text:#A32D2D;--purple-bg:#F0EAFB;--purple-text:#6B21A8;}
@media(prefers-color-scheme:dark){:root{--bg:#1e1e1c;--bg2:#252523;--bg3:#2c2c29;--text:#e8e6df;--text2:#9a9891;--text3:#6b6a65;--border:rgba(255,255,255,0.1);--border2:rgba(255,255,255,0.2);--blue-bg:#0c447c;--blue-text:#B5D4F4;--amber-bg:#633806;--amber-text:#FAC775;--green-bg:#27500A;--green-text:#C0DD97;--gray-bg:#444441;--gray-text:#D3D1C7;--red-bg:#791F1F;--red-text:#F7C1C1;--purple-bg:#3B1A5F;--purple-text:#D8B4FE;}}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg3);color:var(--text);font-size:14px;min-height:100vh}
.login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem}
.login-box{background:var(--bg);border:.5px solid var(--border2);border-radius:var(--radius-lg);width:100%;max-width:380px;overflow:hidden}
.login-header{background:#1a1a1a;padding:2rem;text-align:center}
.login-header h1{font-size:16px;font-weight:400;color:#fff;letter-spacing:.08em;text-transform:uppercase}
.login-header p{font-size:11px;color:rgba(255,255,255,0.4);margin-top:4px}
.login-body{padding:1.5rem}
.login-tabs{display:flex;margin-bottom:1.25rem;border:.5px solid var(--border2);border-radius:var(--radius);overflow:hidden}
.login-tab{flex:1;padding:7px;font-size:13px;border:none;cursor:pointer;background:transparent;color:var(--text2)}
.login-tab.active{background:var(--text);color:var(--bg);font-weight:500}
.field{margin-bottom:.875rem}
.field label{display:block;font-size:12px;color:var(--text2);margin-bottom:4px}
.field input,.field select,.field textarea{width:100%;font-size:13px;padding:8px 10px;border:.5px solid var(--border2);border-radius:var(--radius);background:var(--bg);color:var(--text);outline:none;font-family:inherit}
.field textarea{resize:vertical;min-height:80px;line-height:1.5}
.pass-wrap{position:relative}
.pass-wrap input{padding-right:36px}
.pass-eye{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3);padding:0;display:flex;align-items:center;font-size:16px}
.btn-full{width:100%;background:var(--text);color:var(--bg);border:none;border-radius:var(--radius);height:36px;font-size:13px;cursor:pointer;font-weight:500;margin-top:.25rem}
.btn-full:hover{opacity:.85}
.btn-full:disabled{opacity:.5;cursor:not-allowed}
.login-msg{font-size:12px;text-align:center;margin-top:.75rem;padding:.5rem;border-radius:var(--radius)}
.login-msg.error{background:var(--red-bg);color:var(--red-text)}
.login-msg.success{background:var(--green-bg);color:var(--green-text)}
.app-wrap{display:none;flex-direction:column;min-height:100vh}
.app-wrap.visible{display:flex}
.topbar{background:#1a1a1a;padding:0 1.5rem;height:52px;display:flex;align-items:center;justify-content:space-between}
.topbar-left{display:flex;align-items:center;gap:.75rem}
.topbar-divider{width:1px;height:28px;background:rgba(255,255,255,0.15)}
.topbar-title{font-size:14px;font-weight:400;color:#fff;letter-spacing:.05em}
.topbar-right{display:flex;align-items:center;gap:8px}
.user-pill{font-size:12px;color:rgba(255,255,255,0.6);display:flex;align-items:center;gap:5px}
.user-avatar{width:24px;height:24px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;color:#fff}
.role-badge{font-size:11px;padding:2px 8px;border-radius:20px;border:1px solid}
.role-superadmin{background:rgba(250,174,90,0.15);color:#FAC775;border-color:rgba(250,174,90,0.25)}
.role-admin-ti{background:rgba(21,95,165,0.2);color:#B5D4F4;border-color:rgba(21,95,165,0.3)}
.role-admin-mant{background:rgba(107,33,168,0.2);color:#D8B4FE;border-color:rgba(107,33,168,0.3)}
.btn-topbar{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:var(--radius);padding:0 10px;height:28px;font-size:12px;cursor:pointer;color:rgba(255,255,255,0.7);display:flex;align-items:center;gap:4px}
.btn-topbar:hover{background:rgba(255,255,255,0.15)}
.app{max-width:960px;margin:0 auto;padding:1.5rem 1rem;flex:1}
.page-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.75rem}
.page-head h2{font-size:18px;font-weight:500}
.page-head p{font-size:12px;color:var(--text3);margin-top:2px}
.btn-primary{background:var(--text);color:var(--bg);border:none;border-radius:var(--radius);padding:0 16px;height:36px;font-size:13px;cursor:pointer;font-weight:500;display:flex;align-items:center;gap:6px}
.btn-primary:hover{opacity:.85}
.dept-tabs{display:flex;gap:8px;margin-bottom:1.25rem;flex-wrap:wrap}
.dept-tab{padding:6px 16px;border-radius:20px;border:.5px solid var(--border2);cursor:pointer;background:var(--bg);color:var(--text2);font-size:13px}
.dept-tab:hover{background:var(--bg2)}
.dept-tab.active{background:var(--text);color:var(--bg);font-weight:500;border-color:var(--text)}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1.25rem}
.stat{background:var(--bg2);border-radius:var(--radius);padding:.875rem 1rem}
.stat-label{font-size:11px;color:var(--text3);margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em}
.stat-val{font-size:24px;font-weight:500}
.toolbar{display:flex;gap:8px;margin-bottom:1rem;flex-wrap:wrap}
.toolbar input,.toolbar select{font-size:13px;padding:6px 10px;border-radius:var(--radius);border:.5px solid var(--border2);background:var(--bg);color:var(--text);height:34px;outline:none}
.toolbar input{flex:1;min-width:180px}
.ticket-list{display:flex;flex-direction:column;gap:8px}
.ticket{background:var(--bg);border:.5px solid var(--border);border-radius:var(--radius-lg);padding:.875rem 1rem;cursor:pointer;transition:border-color .15s}
.ticket:hover{border-color:var(--border2)}
.ticket-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px}
.ticket-title{font-size:14px;font-weight:500}
.ticket-id{font-size:11px;color:var(--text3);white-space:nowrap}
.ticket-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:5px}
.badge{font-size:11px;padding:2px 8px;border-radius:20px;font-weight:500}
.b-abierto{background:var(--blue-bg);color:var(--blue-text)}
.b-en-proceso{background:var(--amber-bg);color:var(--amber-text)}
.b-resuelto{background:var(--green-bg);color:var(--green-text)}
.b-cerrado{background:var(--gray-bg);color:var(--gray-text)}
.b-ti{background:var(--blue-bg);color:var(--blue-text)}
.b-mant{background:var(--purple-bg);color:var(--purple-text)}
.cat-tag{font-size:11px;color:var(--text2);display:flex;align-items:center;gap:3px}
.ticket-desc{font-size:12px;color:var(--text2);line-height:1.5;margin-bottom:6px}
.ticket-foot{display:flex;align-items:center;justify-content:space-between;padding-top:7px;border-top:.5px solid var(--border)}
.avatar{width:20px;height:20px;border-radius:50%;background:var(--blue-bg);display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;color:var(--blue-text)}
.user-info-row{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text3)}
.prio{font-size:11px;display:flex;align-items:center;gap:3px}
.prio-alta{color:var(--red-text)}.prio-media{color:var(--amber-text)}.prio-baja{color:var(--green-text)}
.date{font-size:11px;color:var(--text3)}
.empty{text-align:center;padding:3rem 1rem;color:var(--text3);font-size:13px;background:var(--bg);border:.5px solid var(--border);border-radius:var(--radius-lg)}
.empty i{font-size:28px;display:block;margin:0 auto 8px;opacity:.5}
.loading{text-align:center;padding:2rem;color:var(--text3);font-size:13px}
.modal-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);align-items:center;justify-content:center;padding:1rem;z-index:100}
.modal-wrap.open{display:flex}
.modal{background:var(--bg);border-radius:var(--radius-lg);border:.5px solid var(--border2);width:100%;max-width:480px;padding:1.375rem;max-height:90vh;overflow-y:auto}
.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.125rem}
.modal-head h2{font-size:16px;font-weight:500}
.close-btn{background:none;border:none;cursor:pointer;color:var(--text3);font-size:20px;line-height:1;padding:2px 4px}
.close-btn:hover{color:var(--text2)}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.modal-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:1.125rem}
.btn-cancel{background:transparent;border:.5px solid var(--border2);border-radius:var(--radius);padding:0 14px;height:34px;font-size:13px;cursor:pointer;color:var(--text2)}
.btn-cancel:hover{background:var(--bg2)}
.btn-submit{background:var(--text);color:var(--bg);border:none;border-radius:var(--radius);padding:0 16px;height:34px;font-size:13px;cursor:pointer;font-weight:500}
.btn-submit:hover{opacity:.85}
.btn-submit:disabled{opacity:.5;cursor:not-allowed}
.btn-danger{background:transparent;border:.5px solid var(--border2);border-radius:var(--radius);padding:0 14px;height:34px;font-size:13px;cursor:pointer;color:var(--red-text)}
.btn-danger:hover{background:var(--red-bg)}
.detail-body{font-size:13px;color:var(--text2);line-height:1.6;padding:.875rem;background:var(--bg2);border-radius:var(--radius);margin-bottom:1rem}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1rem}
.di{font-size:12px}.di-label{color:var(--text3);margin-bottom:2px}.di-val{font-weight:500}
.status-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1rem}
.status-btn{font-size:12px;padding:4px 12px;border-radius:20px;border:.5px solid var(--border2);cursor:pointer;background:var(--bg2);color:var(--text2)}
.status-btn:hover{background:var(--bg3)}
.status-btn.active{font-weight:500;border-color:var(--text);color:var(--text)}
.status-btn:disabled{opacity:.35;cursor:not-allowed;border-style:dashed}
.section-label{font-size:12px;color:var(--text3);margin-bottom:6px}
.toast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:var(--text);color:var(--bg);padding:10px 20px;border-radius:var(--radius);font-size:13px;display:none;align-items:center;gap:8px;z-index:200;white-space:nowrap;box-shadow:0 4px 12px rgba(0,0,0,.15)}
.toast.show{display:flex}.toast.error{background:var(--red-bg);color:var(--red-text)}
.nav-tabs{display:flex;gap:0;border-bottom:.5px solid var(--border);margin-bottom:1.5rem}
.nav-tab{padding:8px 20px;font-size:13px;border:none;cursor:pointer;background:transparent;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-1px}
.nav-tab:hover{color:var(--text)}
.nav-tab.active{color:var(--text);font-weight:500;border-bottom-color:var(--text)}
.reports-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
.chart-card{background:var(--bg);border:.5px solid var(--border);border-radius:var(--radius-lg);padding:1rem}
.chart-card h3{font-size:13px;font-weight:500;color:var(--text2);margin-bottom:.875rem;text-transform:uppercase;letter-spacing:.04em}
.chart-wrap{position:relative;height:220px}
.report-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1rem}
.summary-card{background:var(--bg);border:.5px solid var(--border);border-radius:var(--radius);padding:.875rem 1rem;text-align:center}
.summary-val{font-size:28px;font-weight:500;margin-bottom:4px}
.summary-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.04em}
.btn-export{background:var(--green-bg);color:var(--green-text);border:.5px solid var(--green-text);border-radius:var(--radius);padding:0 16px;height:36px;font-size:13px;cursor:pointer;font-weight:500;display:flex;align-items:center;gap:6px}
.btn-export:hover{opacity:.85}
.reports-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.75rem}
@media(max-width:600px){.reports-grid{grid-template-columns:1fr}.report-summary{grid-template-columns:1fr 1fr}}
.footer{background:#1a1a1a;padding:12px 1.5rem;text-align:center;font-size:11px;color:rgba(255,255,255,0.3);letter-spacing:.03em}
.footer span{color:rgba(255,255,255,0.5)}
@media(max-width:600px){.stats{grid-template-columns:1fr 1fr}.row2{grid-template-columns:1fr}.topbar-title{font-size:12px}}
</style>
</head>
<body>

<div class="login-screen" id="login-screen">
  <div class="login-box">
    <div class="login-header">
      <h1>Sistema de Solicitudes</h1>
      <p>Distrito Hotelero Plaza San Martín</p>
    </div>
    <div class="login-body">
      <div class="login-tabs">
        <button class="login-tab active" id="tab-login" onclick="switchTab('login')">Iniciar sesión</button>
        <button class="login-tab" id="tab-register" onclick="switchTab('register')">Registrarse</button>
      </div>
      <div id="form-login">
        <div class="field"><label>Correo electrónico</label><input id="l-email" type="email" placeholder="tucorreo@empresa.com"></div>
        <div class="field"><label>Contraseña</label>
          <div class="pass-wrap">
            <input id="l-pass" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
            <button class="pass-eye" type="button" onclick="togglePass('l-pass','l-eye')"><i id="l-eye" class="ti ti-eye"></i></button>
          </div>
        </div>
        <button class="btn-full" id="btn-login" onclick="doLogin()">Iniciar sesión</button>
      </div>
      <div id="form-register" style="display:none">
        <div class="field"><label>Nombre completo</label><input id="r-name" type="text" placeholder="Tu nombre"></div>
        <div class="field"><label>Correo electrónico</label><input id="r-email" type="email" placeholder="tucorreo@empresa.com"></div>
        <div class="field"><label>Contraseña</label>
          <div class="pass-wrap">
            <input id="r-pass" type="password" placeholder="Mínimo 6 caracteres" onkeydown="if(event.key==='Enter')doRegister()">
            <button class="pass-eye" type="button" onclick="togglePass('r-pass','r-eye')"><i id="r-eye" class="ti ti-eye"></i></button>
          </div>
        </div>
        <button class="btn-full" id="btn-register" onclick="doRegister()">Crear cuenta</button>
      </div>
      <div id="login-msg" class="login-msg" style="display:none"></div>
    </div>
  </div>
</div>

<div class="app-wrap" id="app-wrap">
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-title">DISTRITO HOTELERO — SOLICITUDES</div>
      <div class="topbar-divider"></div>
      <div style="font-size:11px;color:rgba(255,255,255,0.4)">Plaza San Martín</div>
    </div>
    <div class="topbar-right">
      <span id="topbar-role-badge" class="role-badge" style="display:none"></span>
      <div class="user-pill"><div class="user-avatar" id="topbar-avatar">—</div><span id="topbar-name"></span></div>
      <button class="btn-topbar" onclick="doLogout()"><i class="ti ti-logout"></i>Salir</button>
    </div>
  </div>
  <div class="app">
    <div id="nav-tabs-wrap" style="display:none">
      <div class="nav-tabs">
        <button class="nav-tab active" id="nav-solicitudes" onclick="showView('solicitudes')"><i class="ti ti-ticket" style="margin-right:5px"></i>Solicitudes</button>
        <button class="nav-tab" id="nav-reportes" onclick="showView('reportes')"><i class="ti ti-chart-bar" style="margin-right:5px"></i>Reportes</button>
      </div>
    </div>
    <div id="view-solicitudes">
      <div class="page-head">
        <div><h2 id="page-title">Mis solicitudes</h2><p id="page-sub"></p></div>
        <button class="btn-primary" onclick="openNew()"><i class="ti ti-plus"></i>Nueva solicitud</button>
      </div>
    <div id="dept-tabs-wrap" style="display:none">
      <div class="dept-tabs">
        <button class="dept-tab active" id="tab-todos" onclick="setDeptFilter('todos')"><i class="ti ti-layout-grid" style="margin-right:4px"></i>Todos</button>
        <button class="dept-tab" id="tab-TI" onclick="setDeptFilter('TI')"><i class="ti ti-device-desktop" style="margin-right:4px"></i>TI</button>
        <button class="dept-tab" id="tab-Mantenimiento" onclick="setDeptFilter('Mantenimiento')"><i class="ti ti-tool" style="margin-right:4px"></i>Mantenimiento</button>
      </div>
    </div>
    <div id="stats-wrap" style="display:none">
      <div class="stats">
        <div class="stat"><div class="stat-label">Total</div><div class="stat-val" id="s-total">—</div></div>
        <div class="stat"><div class="stat-label">Abiertos</div><div class="stat-val" id="s-open">—</div></div>
        <div class="stat"><div class="stat-label">En proceso</div><div class="stat-val" id="s-proc">—</div></div>
        <div class="stat"><div class="stat-label">Resueltos</div><div class="stat-val" id="s-done">—</div></div>
      </div>
      <div class="toolbar">
        <input type="text" id="search" placeholder="Buscar solicitudes…" oninput="render()">
        <select id="f-estado" onchange="render()"><option value="">Todos los estados</option><option>Abierto</option><option>En proceso</option><option>Resuelto</option><option>Cerrado</option></select>
        <select id="f-cat" onchange="render()"><option value="">Todas las categorías</option></select>
        <select id="f-hotel" onchange="render()"><option value="">Todos los hoteles</option><option>Hotel Plaza Juan Carlos</option><option>Hotel Plaza San Martín</option><option>Hotel Plaza del Libertador</option><option>Hotel Plaza del General</option></select>
        <select id="f-prio" onchange="render()"><option value="">Todas las prioridades</option><option>Alta</option><option>Media</option><option>Baja</option></select>
      </div>
    </div>
    <div class="ticket-list" id="list" style="margin-top:.5rem"><div class="loading"><i class="ti ti-loader" style="font-size:20px;display:block;margin:0 auto 8px"></i>Cargando…</div></div>
  </div>
    </div><!-- end view-solicitudes -->

    <div id="view-reportes" style="display:none">
      <div class="reports-head">
        <div><h2>Reportes</h2><p id="report-sub" style="font-size:12px;color:var(--text3);margin-top:2px"></p></div>
        <button class="btn-export" onclick="exportExcel()"><i class="ti ti-file-spreadsheet"></i>Exportar a Excel</button>
      </div>
      <!-- Filtros de reporte -->
      <div style="background:var(--bg);border:.5px solid var(--border);border-radius:var(--radius-lg);padding:1rem;margin-bottom:1rem">
        <div style="font-size:12px;font-weight:500;color:var(--text2);margin-bottom:.75rem"><i class="ti ti-filter" style="margin-right:4px"></i>Filtrar reporte</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end">
          <div>
            <div style="font-size:11px;color:var(--text3);margin-bottom:3px">Departamento</div>
            <select id="rf-dept" style="font-size:12px;padding:5px 8px;border:.5px solid var(--border2);border-radius:var(--radius);background:var(--bg);color:var(--text);height:30px;outline:none">
              <option value="">Todos</option><option>TI</option><option>Mantenimiento</option>
            </select>
          </div>
          <div>
            <div style="font-size:11px;color:var(--text3);margin-bottom:3px">Hotel</div>
            <select id="rf-hotel" style="font-size:12px;padding:5px 8px;border:.5px solid var(--border2);border-radius:var(--radius);background:var(--bg);color:var(--text);height:30px;outline:none">
              <option value="">Todos</option><option>Hotel Plaza Juan Carlos</option><option>Hotel Plaza San Martín</option><option>Hotel Plaza del Libertador</option><option>Hotel Plaza del General</option>
            </select>
          </div>
          <div>
            <div style="font-size:11px;color:var(--text3);margin-bottom:3px">Estado</div>
            <select id="rf-estado" style="font-size:12px;padding:5px 8px;border:.5px solid var(--border2);border-radius:var(--radius);background:var(--bg);color:var(--text);height:30px;outline:none">
              <option value="">Todos</option><option>Abierto</option><option>En proceso</option><option>Resuelto</option><option>Cerrado</option>
            </select>
          </div>
          <div>
            <div style="font-size:11px;color:var(--text3);margin-bottom:3px">Prioridad</div>
